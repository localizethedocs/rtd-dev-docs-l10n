#: ../../../tests.rst:2
msgid "Testing"
msgstr ""

#: ../../../tests.rst:4
msgid ""
"Before contributing to Read the Docs, make sure your patch passes our test "
"suite and your code style passes our code linting suite."
msgstr ""

#: ../../../tests.rst:7
msgid ""
"Read the Docs uses `Tox`_ to execute testing and linting procedures. Tox is "
"the only dependency you need to run linting or our test suite, the remainder "
"of our requirements will be installed by Tox into environment specific "
"virtualenv paths. Before testing, make sure you have Tox installed:"
msgstr ""

#: ../../../tests.rst:15
msgid "pip install tox"
msgstr ""

#: ../../../tests.rst:17
msgid "Running tests"
msgstr ""

#: ../../../tests.rst:19
msgid ""
"The test suite is split into separate tox environments that match the CI "
"pipeline:"
msgstr ""

#: ../../../tests.rst:27
msgid ""
"tox -e py312          # Core tests (no search, no proxito)\n"
"tox -e search         # Search tests (requires Elasticsearch)\n"
"tox -e proxito        # Proxito tests"
msgstr ""

#: ../../../tests.rst:28
msgid "To run all test suites at once:"
msgstr ""

#: ../../../tests.rst:33
msgid "tox -e py312,search,proxito"
msgstr ""

#: ../../../tests.rst:34
msgid "To run a subset of tests:"
msgstr ""

#: ../../../tests.rst:39
msgid "tox -e py312 -- -k test_celery"
msgstr ""

#: ../../../tests.rst:42
msgid ""
